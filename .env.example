# Google Sheets test config
SPREADSHEET_ID=SINU_LEHE_ID
CREDENTIALS_FILE=credentials_sample.json

# Camera stream URL
STREAM_URL=https://example.com/camera-stream

# FastALPR models. These defaults are downloaded and cached on first inference.
ALPR_DETECTOR_MODEL=yolo-v9-t-384-license-plate-end2end
ALPR_OCR_MODEL=cct-s-v2-global-model
ALPR_DETECTOR_CONFIDENCE=0.8

# Portable default. Examples: CoreMLExecutionProvider, CUDAExecutionProvider,
# OpenVINOExecutionProvider. Use "auto" to let ONNX Runtime select providers.
ALPR_EXECUTION_PROVIDER=CPUExecutionProvider
